@model List<Guardias.Models.Ronda>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Rondas";
    ViewData["AdminSection"] = "rondas";
    ViewData["PageSub"] = "Revisa y firma las rondas de los guardias";
    var edificios = ViewBag.EdificiosList as List<Guardias.Models.Edificio>;
    int? sel = ViewBag.SelectedEdificio as int?;
}

<div class="admin-toolbar">
    <form method="get" asp-action="Rondas" style="display:flex;gap:8px;align-items:center;flex:1;">
        <select name="edificioId" class="form-admin-control" style="min-width:180px;" onchange="this.form.submit()"
                asp-items="@(new SelectList(edificios ?? new(), "Id", "Nombre", sel))">
            <option value="">Todos los edificios</option>
        </select>
        @if (sel.HasValue)
        {
            <a href="/Admin/Rondas" class="btn-admin btn-admin-secondary" style="padding:8px 14px;white-space:nowrap;">
                <i class="bi bi-x"></i> Quitar filtro
            </a>
        }
    </form>
</div>

<div class="admin-card" style="padding:0;overflow:hidden;">
    @if (!Model.Any())
    {
        <div style="padding:40px;text-align:center;color:var(--text2);">
            <i class="bi bi-clipboard2" style="font-size:40px;display:block;margin-bottom:10px;"></i>
            No hay rondas registradas.
        </div>
    }
    else
    {
        <div class="table-scroll-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Guardia</th>
                    <th>Edificio</th>
                    <th>Fecha/Hora</th>
                    <th>Fotos</th>
                    <th>Incidencias</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td style="color:var(--text2);">@r.Id</td>
                        <td style="font-weight:500;">@(r.Guardia?.Nombre ?? "—")</td>
                        <td style="color:var(--text2);">@r.Edificio?.Nombre</td>
                        <td style="color:var(--text2);">@r.FechaHora.ToString("dd/MM/yy HH:mm")</td>
                        <td>
                            @{ var totalFotos = r.AreaRondas.Sum(ar => ar.Fotos.Count); }
                            @if (r.AreaRondas.Any(ar => ar.Fotos.Any()))
                            {
                                <span class="badge-ios badge-done">@totalFotos foto(s)</span>
                            }
                            else
                            {
                                <span style="color:var(--text2);">Sin fotos</span>
                            }
                        </td>
                        <td>
                            @if (r.Incidencias.Any())
                            {
                                <span class="badge-ios badge-open">@r.Incidencias.Count</span>
                            }
                            else
                            {
                                <span style="color:var(--text2);">—</span>
                            }
                        </td>
                        <td>
                            @switch (r.Estado)
                            {
                                case Guardias.Models.EstadoRonda.EnCurso:
                                    <span class="badge-ios badge-running">En curso</span>
                                    break;
                                case Guardias.Models.EstadoRonda.Finalizada:
                                    <span class="badge-ios badge-done">Finalizada</span>
                                    break;
                                case Guardias.Models.EstadoRonda.FirmadaSupervisor:
                                    <span class="badge-ios badge-signed">Firmada</span>
                                    break;
                            }
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                <a href="/Admin/DetalleRonda/@r.Id" class="btn-admin btn-admin-secondary" style="padding:6px 12px;font-size:13px;">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                                <a href="/Admin/ExportarPdfRonda/@r.Id" target="_blank" class="btn-admin btn-admin-secondary" style="padding:6px 12px;font-size:13px;">
                                    <i class="bi bi-file-earmark-pdf"></i> PDF
                                </a>
                                @if (r.Estado == Guardias.Models.EstadoRonda.Finalizada)
                                {
                                    <a href="/Admin/FirmarRonda/@r.Id" class="btn-admin btn-admin-primary" style="padding:6px 12px;font-size:13px;">
                                        <i class="bi bi-pen"></i> Firmar
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>
