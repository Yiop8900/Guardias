@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
    ViewData["AdminSection"] = "dashboard";
}

<div class="admin-stat-grid">
    <div class="admin-stat">
        <div class="admin-stat-icon" style="color:var(--blue);"><i class="bi bi-people-fill"></i></div>
        <div class="admin-stat-value">@ViewBag.TotalGuardias</div>
        <div class="admin-stat-label">Guardias activos</div>
    </div>
    <div class="admin-stat">
        <div class="admin-stat-icon" style="color:var(--orange);"><i class="bi bi-building"></i></div>
        <div class="admin-stat-value">@ViewBag.TotalEdificios</div>
        <div class="admin-stat-label">Edificios</div>
    </div>
    <div class="admin-stat">
        <div class="admin-stat-icon" style="color:var(--green);"><i class="bi bi-clipboard2-check"></i></div>
        <div class="admin-stat-value">@ViewBag.RondasHoy</div>
        <div class="admin-stat-label">Rondas hoy</div>
    </div>
    <div class="admin-stat">
        <div class="admin-stat-icon" style="color:#7B1FA2;"><i class="bi bi-pencil-square"></i></div>
        <div class="admin-stat-value">@ViewBag.RondasPendientesFirma</div>
        <div class="admin-stat-label">Pendientes firma</div>
    </div>
    <div class="admin-stat">
        <div class="admin-stat-icon" style="color:var(--red);"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <div class="admin-stat-value">@ViewBag.IncidenciasAbiertas</div>
        <div class="admin-stat-label">Incidencias abiertas</div>
    </div>
    <div class="admin-stat">
        <div class="admin-stat-icon" style="color:var(--orange);"><i class="bi bi-list-task"></i></div>
        <div class="admin-stat-value">@ViewBag.TareasPendientes</div>
        <div class="admin-stat-label">Tareas pendientes</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;">
    <a href="/Admin/Guardias" class="admin-card" style="text-decoration:none;color:inherit;display:block;transition:transform 0.1s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
        <div style="font-size:28px;color:var(--blue);margin-bottom:10px;"><i class="bi bi-people-fill"></i></div>
        <div style="font-weight:600;font-size:16px;">Gestionar Guardias</div>
        <div style="color:var(--text2);font-size:13px;margin-top:4px;">Crear, editar y asignar turnos</div>
    </a>
    <a href="/Admin/Edificios" class="admin-card" style="text-decoration:none;color:inherit;display:block;transition:transform 0.1s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
        <div style="font-size:28px;color:var(--orange);margin-bottom:10px;"><i class="bi bi-building"></i></div>
        <div style="font-weight:600;font-size:16px;">Gestionar Edificios</div>
        <div style="color:var(--text2);font-size:13px;margin-top:4px;">Administrar ubicaciones</div>
    </a>
    <a href="/Admin/Tareas" class="admin-card" style="text-decoration:none;color:inherit;display:block;transition:transform 0.1s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
        <div style="font-size:28px;color:var(--green);margin-bottom:10px;"><i class="bi bi-list-task"></i></div>
        <div style="font-weight:600;font-size:16px;">Programar Tareas</div>
        <div style="color:var(--text2);font-size:13px;margin-top:4px;">Tareas por turno y hora</div>
    </a>
    <a href="/Admin/Rondas" class="admin-card" style="text-decoration:none;color:inherit;display:block;transition:transform 0.1s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
        <div style="font-size:28px;color:#7B1FA2;margin-bottom:10px;"><i class="bi bi-clipboard2-check"></i></div>
        <div style="font-weight:600;font-size:16px;">Firmar Rondas</div>
        <div style="color:var(--text2);font-size:13px;margin-top:4px;">Supervisar y firmar rondas</div>
    </a>
    <a href="/Admin/Incidencias" class="admin-card" style="text-decoration:none;color:inherit;display:block;transition:transform 0.1s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
        <div style="font-size:28px;color:var(--red);margin-bottom:10px;"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <div style="font-weight:600;font-size:16px;">Gestionar Incidencias</div>
        <div style="color:var(--text2);font-size:13px;margin-top:4px;">Actualizar estado y notas</div>
    </a>
</div>
