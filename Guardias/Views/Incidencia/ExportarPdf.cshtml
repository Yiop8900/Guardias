@model Guardias.Models.Incidencia
@{
    Layout = null;
    var fotos = Model.Ronda?.AreaRondas
        .OrderBy(ar => ar.Area?.Orden)
        .SelectMany(ar => ar.Fotos.Select(f => (RutaFoto: f.RutaFoto, FechaCaptura: f.FechaCaptura, Area: ar.Area?.Nombre)))
        .ToList() ?? new List<(string RutaFoto, DateTime FechaCaptura, string? Area)>();
    var operador = Model.Ronda?.Guardia?.Nombre ?? Model.Ronda?.NombreOperador ?? "—";
    var severidadLabel = Model.Severidad switch {
        Guardias.Models.SeveridadIncidencia.Grave => "Grave",
        Guardias.Models.SeveridadIncidencia.Moderada => "Moderada",
        _ => "Leve"
    };
    var severidadColor = Model.Severidad switch {
        Guardias.Models.SeveridadIncidencia.Grave => "#c62828",
        Guardias.Models.SeveridadIncidencia.Moderada => "#e65100",
        _ => "#2e7d32"
    };
    var estadoLabel = Model.Estado switch {
        Guardias.Models.EstadoIncidencia.Cerrada => "Cerrada",
        Guardias.Models.EstadoIncidencia.EnProceso => "En proceso",
        _ => "Abierta"
    };
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reporte Incidencia #@Model.Id — @Model.Ronda?.Edificio?.Nombre</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; color: #1a1a1a; background: #fff; }

        .page { max-width: 800px; margin: 0 auto; padding: 32px 40px; }

        /* ---- Header ---- */
        .report-header { display: flex; align-items: center; gap: 16px; border-bottom: 3px solid #1e3a6e; padding-bottom: 18px; margin-bottom: 20px; }
        .report-logo { width: 60px; height: 60px; object-fit: contain; flex-shrink: 0; }
        .report-title-block { flex: 1; }
        .report-title { font-size: 20px; font-weight: 700; color: #1e3a6e; letter-spacing: 0.5px; }
        .report-subtitle { font-size: 12px; color: #555; margin-top: 2px; }
        .report-id { font-size: 24px; font-weight: 800; color: #1e3a6e; white-space: nowrap; }

        /* ---- Meta grid ---- */
        .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid #ddd; border-radius: 6px; overflow: hidden; margin-bottom: 20px; }
        .meta-cell { padding: 9px 14px; border-bottom: 1px solid #eee; }
        .meta-cell:nth-last-child(-n+2) { border-bottom: none; }
        .meta-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.7px; color: #888; margin-bottom: 3px; }
        .meta-value { font-weight: 600; font-size: 13px; }
        .badge { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }

        /* ---- Sections ---- */
        .section { margin-bottom: 20px; }
        .section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: #1e3a6e; border-bottom: 1.5px solid #c5d5ea; padding-bottom: 5px; margin-bottom: 10px; }
        .description-box { background: #f7f9fc; border: 1px solid #dde4ee; border-radius: 6px; padding: 14px 16px; font-size: 14px; line-height: 1.6; white-space: pre-wrap; }
        .notes-box { background: #f1f8f1; border: 1px solid #b8ddb8; border-radius: 6px; padding: 14px 16px; font-size: 14px; line-height: 1.6; color: #1b5e20; white-space: pre-wrap; }

        /* ---- Photos ---- */
        .photos-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .photo-item { break-inside: avoid; }
        .photo-item img { width: 100%; height: 200px; object-fit: cover; border-radius: 6px; border: 1px solid #ddd; display: block; }
        .photo-caption { font-size: 11px; color: #666; margin-top: 4px; text-align: center; }

        /* ---- Signature ---- */
        .signature-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 8px; }
        .signature-box { border-top: 1.5px solid #333; padding-top: 8px; }
        .signature-label { font-size: 11px; color: #555; text-align: center; }
        .signature-name { font-size: 12px; font-weight: 600; text-align: center; margin-top: 2px; }
        .signature-space { height: 52px; }

        /* ---- Footer ---- */
        .report-footer { border-top: 1px solid #ddd; margin-top: 28px; padding-top: 10px; font-size: 11px; color: #999; display: flex; justify-content: space-between; }

        /* ---- Print button ---- */
        .print-bar { background: #1e3a6e; color: #fff; padding: 10px 24px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
        .print-bar h3 { font-size: 14px; font-weight: 600; }
        .btn-print { background: #fff; color: #1e3a6e; border: none; padding: 7px 20px; border-radius: 6px; font-size: 13px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 6px; }
        .btn-back { background: transparent; color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.35); padding: 7px 16px; border-radius: 6px; font-size: 13px; cursor: pointer; text-decoration: none; }

        @@media print {
            .print-bar { display: none !important; }
            body { background: #fff; }
            .page { padding: 20px 28px; max-width: 100%; }
            .photos-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>

    <!-- Print bar (hidden on print) -->
    <div class="print-bar">
        <div>
            <h3>Reporte de Incidencia #@Model.Id</h3>
            <div style="font-size:12px;opacity:.75;">@Model.Ronda?.Edificio?.Nombre — @Model.FechaCreacion.ToString("dd/MM/yyyy")</div>
        </div>
        <div style="display:flex;gap:8px;">
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/GestionarIncidencia/@Model.Id" class="btn-back">← Volver</a>
            }
            else
            {
                <a href="/Incidencia/Detalle/@Model.Id" class="btn-back">← Volver</a>
            }
            <button class="btn-print" id="btnPrint">🖨 Imprimir / Guardar PDF</button>
        </div>
    </div>

    <div class="page">

        <!-- Header -->
        <div class="report-header">
            <img src="@Url.Content("~/favicon.png")" alt="Logo" class="report-logo" />
            <div class="report-title-block">
                <div class="report-title">Control de Ronda</div>
                <div class="report-subtitle">@(Model.Ronda?.Edificio?.Nombre ?? "Edificio") · Sistema de Gestión de Seguridad</div>
            </div>
            <div class="report-id">INC-@Model.Id.ToString("D4")</div>
        </div>

        <!-- Meta grid -->
        <div class="meta-grid">
            <div class="meta-cell">
                <div class="meta-label">Fecha de registro</div>
                <div class="meta-value">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div class="meta-cell">
                <div class="meta-label">Edificio</div>
                <div class="meta-value">@(Model.Ronda?.Edificio?.Nombre ?? "—")</div>
            </div>
            <div class="meta-cell">
                <div class="meta-label">Operador / Guardia</div>
                <div class="meta-value">@operador</div>
            </div>
            <div class="meta-cell">
                <div class="meta-label">Ronda asociada</div>
                <div class="meta-value">#@Model.RondaId — @Model.Ronda?.FechaHora.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div class="meta-cell">
                <div class="meta-label">Severidad</div>
                <div class="meta-value">
                    <span class="badge" style="background:@severidadColor;color:#fff;">@severidadLabel</span>
                </div>
            </div>
            <div class="meta-cell">
                <div class="meta-label">Estado</div>
                <div class="meta-value">
                    @if (Model.Estado == Guardias.Models.EstadoIncidencia.Cerrada)
                    {
                        <span class="badge" style="background:#2e7d32;color:#fff;">@estadoLabel</span>
                    }
                    else if (Model.Estado == Guardias.Models.EstadoIncidencia.EnProceso)
                    {
                        <span class="badge" style="background:#e65100;color:#fff;">@estadoLabel</span>
                    }
                    else
                    {
                        <span class="badge" style="background:#1565c0;color:#fff;">@estadoLabel</span>
                    }
                </div>
            </div>
        </div>

        <!-- Description -->
        <div class="section">
            <div class="section-title">Descripción de la incidencia</div>
            <div class="description-box">@Model.Descripcion</div>
        </div>

        <!-- Closing notes -->
        @if (!string.IsNullOrWhiteSpace(Model.NotasCierre))
        {
            <div class="section">
                <div class="section-title">Resolución / Notas de cierre</div>
                <div class="notes-box">@Model.NotasCierre
                    @if (Model.FechaCierre.HasValue)
                    {
                        <div style="margin-top:8px;font-size:12px;color:#388e3c;">Cerrada el @Model.FechaCierre.Value.ToString("dd/MM/yyyy HH:mm")</div>
                    }
                </div>
            </div>
        }

        <!-- Photos -->
        @if (fotos.Any())
        {
            <div class="section">
                <div class="section-title">Imágenes adjuntas (@fotos.Count foto(s))</div>
                <div class="photos-grid">
                    @foreach (var foto in fotos)
                    {
                        <div class="photo-item">
                            <img src="@foto.RutaFoto" alt="Foto de ronda" />
                            <div class="photo-caption">
                                @if (!string.IsNullOrWhiteSpace(foto.Area)) { <span>@foto.Area · </span> }
                                @foto.FechaCaptura.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Signature section -->
        <div class="section" style="margin-top:36px;">
            <div class="section-title">Firmas</div>
            <div class="signature-grid">
                <div>
                    <div class="signature-space"></div>
                    <div class="signature-box">
                        <div class="signature-label">Operador / Guardia</div>
                        <div class="signature-name">@operador</div>
                    </div>
                </div>
                <div>
                    <div class="signature-space"></div>
                    <div class="signature-box">
                        <div class="signature-label">Supervisor / Responsable</div>
                        <div class="signature-name">&nbsp;</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="report-footer">
            <span>Control de Ronda · @(Model.Ronda?.Edificio?.Nombre)</span>
            <span>Generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
        </div>

    </div>

<script>
    document.getElementById('btnPrint').addEventListener('click', function () {
        window.print();
    });
</script>

</body>
</html>
