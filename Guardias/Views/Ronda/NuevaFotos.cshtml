@model Guardias.Models.Ronda
@{
    ViewData["ActiveTab"] = "nueva";
}

<div class="page-header">
    <h2>Nueva Ronda</h2>
    <p>Registra las fotos y observaciones</p>
</div>

<div class="progress-steps">
    <div class="progress-step done"></div>
    <div class="progress-step done"></div>
</div>

<div class="form-section" style="margin-bottom:10px;background:#f8f8fc;">
    <div style="display:flex;gap:16px;flex-wrap:wrap;font-size:14px;color:var(--text2);">
        <span><i class="bi bi-person me-1"></i><strong style="color:var(--text);">@Model.Guardia?.Nombre</strong></span>
        <span><i class="bi bi-building me-1"></i>@Model.Edificio?.Nombre</span>
        <span><i class="bi bi-clock me-1"></i>@Model.FechaHora.ToString("HH:mm")</span>
    </div>
</div>

@if (ViewContext.ModelState.ErrorCount > 0)
{
    <div class="alert-ios alert-error mb-3" id="photo-error">
        @foreach (var entry in ViewContext.ModelState.Values)
        {
            foreach (var err in entry.Errors)
            {
                <div><i class="bi bi-exclamation-circle me-1"></i>@err.ErrorMessage</div>
            }
        }
    </div>
}

<form method="post" enctype="multipart/form-data" asp-controller="Ronda" asp-action="NuevaFotos" asp-route-id="@Model.Id" id="ronda-form">
    @Html.AntiForgeryToken()

    <!-- Photos -->
    <div class="form-section">
        <label class="form-label-ios">Fotos de la ronda <span style="color:var(--red)">*</span></label>
        <div class="photo-zone" id="drop-zone" onclick="document.getElementById('fileInput').click()">
            <i class="bi bi-camera photo-zone-icon"></i>
            <p>Tomar foto o seleccionar imagen</p>
            <p style="font-size:12px;margin-top:4px;">JPG, PNG, WEBP · Máx 10 MB c/u</p>
        </div>
        <input type="file" id="fileInput" name="fotos" multiple accept="image/*" onchange="handleFiles(this.files)" />
        <div class="photo-grid" id="photoGrid"></div>
        <div class="photo-required-msg" id="noPhotoMsg">
            <i class="bi bi-exclamation-circle me-1"></i> Debe subir al menos una foto para finalizar la ronda.
        </div>
    </div>

    <!-- Incident report -->
    <div class="form-section">
        <label class="form-label-ios" for="reporteIncidencias">Reporte de incidencias <span style="font-weight:400;color:var(--text2)">(opcional)</span></label>
        <textarea id="reporteIncidencias" name="reporteIncidencias" class="form-control-ios"
                  rows="4" placeholder="Describe cualquier incidencia ocurrida durante la ronda..."></textarea>

        <div id="severidad-group" style="margin-top:14px;display:none;">
            <label class="form-label-ios">Severidad de la incidencia</label>
            <select name="severidad" class="form-control-ios">
                <option value="0">Leve</option>
                <option value="1">Moderada</option>
                <option value="2">Grave</option>
            </select>
        </div>
    </div>

    <div class="btn-row">
        <a href="/Ronda/Historial" class="btn-secondary-ios" onclick="return confirmCancel()">Atrás</a>
        <button type="submit" class="btn-primary-ios" id="btn-finalizar" onclick="return validateForm()">
            <i class="bi bi-check-circle"></i> Finalizar ronda
        </button>
    </div>
</form>

@section Scripts {
<script>
let selectedFiles = [];

function handleFiles(files) {
    for (let f of files) {
        if (!f.type.startsWith('image/')) continue;
        if (selectedFiles.find(x => x.name === f.name && x.size === f.size)) continue;
        selectedFiles.push(f);
    }
    renderPreviews();
    updateFileInput();
    document.getElementById('noPhotoMsg').classList.remove('show');
}

function renderPreviews() {
    const grid = document.getElementById('photoGrid');
    grid.innerHTML = '';
    selectedFiles.forEach((f, i) => {
        const reader = new FileReader();
        reader.onload = e => {
            const div = document.createElement('div');
            div.className = 'photo-thumb';
            div.innerHTML = `<img src="${e.target.result}" alt="foto">
                <button type="button" class="remove-btn" onclick="removePhoto(${i})">×</button>`;
            grid.appendChild(div);
        };
        reader.readAsDataURL(f);
    });
}

function removePhoto(i) {
    selectedFiles.splice(i, 1);
    renderPreviews();
    updateFileInput();
}

function updateFileInput() {
    const dt = new DataTransfer();
    selectedFiles.forEach(f => dt.items.add(f));
    document.getElementById('fileInput').files = dt.files;
}

function validateForm() {
    if (selectedFiles.length === 0) {
        document.getElementById('noPhotoMsg').classList.add('show');
        document.getElementById('drop-zone').scrollIntoView({ behavior: 'smooth' });
        return false;
    }
    return true;
}

function confirmCancel() {
    return confirm('¿Cancelar la ronda? Los datos ingresados se perderán.');
}

// Show severity when report is written
document.getElementById('reporteIncidencias').addEventListener('input', function() {
    document.getElementById('severidad-group').style.display = this.value.trim() ? 'block' : 'none';
});

// Drag and drop
const zone = document.getElementById('drop-zone');
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag'); });
zone.addEventListener('dragleave', () => zone.classList.remove('drag'));
zone.addEventListener('drop', e => {
    e.preventDefault();
    zone.classList.remove('drag');
    handleFiles(e.dataTransfer.files);
});
</script>
}
