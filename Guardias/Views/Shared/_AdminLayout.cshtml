<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin · Control de Ronda</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
</head>
<body style="background:var(--bg);">

<div class="overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="admin-wrapper">
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <a href="/Admin" class="admin-sidebar-brand">
            <div class="icon"><img src="@Url.Content("~/favicon.png")" alt="Logo" /></div>
            <div>
                <div class="name">Control de Ronda</div>
                <div class="sub">Panel administrador</div>
            </div>
        </a>

        <div class="admin-nav-section">Principal</div>
        <a href="/Admin" class="admin-nav-link @(ViewData["AdminSection"] as string == "dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="admin-nav-section">Configuración</div>
        <a href="/Admin/Guardias" class="admin-nav-link @(ViewData["AdminSection"] as string == "guardias" ? "active" : "")">
            <i class="bi bi-people-fill"></i> Guardias
        </a>
        <a href="/Admin/Edificios" class="admin-nav-link @(ViewData["AdminSection"] as string == "edificios" ? "active" : "")">
            <i class="bi bi-building"></i> Edificios
        </a>
        <a href="/Admin/Areas" class="admin-nav-link @(ViewData["AdminSection"] as string == "areas" ? "active" : "")">
            <i class="bi bi-map"></i> Áreas
        </a>
        <a href="/Admin/Usuarios" class="admin-nav-link @(ViewData["AdminSection"] as string == "usuarios" ? "active" : "")">
            <i class="bi bi-person-lock"></i> Usuarios
        </a>

        <div class="admin-nav-section">Gestión</div>
        <a href="/Admin/Tareas" class="admin-nav-link @(ViewData["AdminSection"] as string == "tareas" ? "active" : "")">
            <i class="bi bi-list-task"></i> Tareas
        </a>
        <a href="/Admin/Rondas" class="admin-nav-link @(ViewData["AdminSection"] as string == "rondas" ? "active" : "")">
            <i class="bi bi-clipboard2-check"></i> Rondas
        </a>
        <a href="/Admin/Incidencias" class="admin-nav-link @(ViewData["AdminSection"] as string == "incidencias" ? "active" : "")">
            <i class="bi bi-exclamation-triangle-fill"></i> Incidencias
        </a>

        <div class="admin-nav-section">Sistema</div>
        <a href="/Ronda/Historial" class="admin-nav-link">
            <i class="bi bi-phone"></i> Ver app guardia
        </a>
    </aside>

    <!-- Main content -->
    <main class="admin-main">
        <div class="admin-topbar">
            <div>
                <button class="admin-menu-toggle" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
            </div>
            <div style="flex:1">
                <div class="admin-page-title">@ViewData["Title"]</div>
                @if (ViewData["PageSub"] != null)
                {
                    <div class="admin-page-sub">@ViewData["PageSub"]</div>
                }
            </div>
            <form method="post" asp-controller="Account" asp-action="Logout" style="margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit" title="Cerrar sesión"
                        style="background:none;border:none;padding:8px;font-size:18px;color:var(--text2);cursor:pointer;display:flex;align-items:center;gap:6px;font-size:13px;">
                    <i class="bi bi-box-arrow-right"></i> Salir
                </button>
            </form>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert-ios alert-success mb-3">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            </div>
        }

        @RenderBody()
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
<script>
    function toggleSidebar() {
        document.getElementById('adminSidebar').classList.toggle('open');
        document.getElementById('sidebarOverlay').classList.toggle('show');
    }
    function closeSidebar() {
        document.getElementById('adminSidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('show');
    }

    // SweetAlert2 confirm para formularios de eliminación
    function confirmarEliminar(formId, titulo, texto) {
        Swal.fire({
            title: titulo || '¿Eliminar?',
            text: texto || 'Esta acción no se puede deshacer.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#E05555',
            cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="bi bi-trash"></i> Sí, eliminar',
            cancelButtonText: 'Cancelar',
            reverseButtons: true,
            focusCancel: true
        }).then(result => {
            if (result.isConfirmed) document.getElementById(formId).submit();
        });
        return false;
    }

    function initResponsiveTables() {
        document.querySelectorAll('.admin-table').forEach(function(table) {
            if (table.dataset.respInit) return;
            table.dataset.respInit = '1';
            var headers = [];
            table.querySelectorAll('thead th').forEach(function(th) {
                var text = '';
                th.childNodes.forEach(function(n) { if (n.nodeType === 3) text += n.textContent; });
                headers.push(text.trim() || th.textContent.trim());
            });
            table.querySelectorAll('tbody tr').forEach(function(row) {
                var cells = Array.from(row.querySelectorAll('td'));
                cells.forEach(function(cell, i) {
                    if (i === 0 || i === cells.length - 1 || !headers[i]) return;
                    var lbl = document.createElement('span');
                    lbl.className = 'td-label';
                    lbl.textContent = headers[i];
                    var val = document.createElement('span');
                    val.className = 'td-value';
                    while (cell.firstChild) val.appendChild(cell.firstChild);
                    cell.appendChild(lbl);
                    cell.appendChild(val);
                });
                var lastCell = cells[cells.length - 1];
                if (cells.length >= 2 && lastCell && lastCell.querySelector('a, button')) {
                    var btn = document.createElement('button');
                    btn.className = 'card-actions-btn';
                    btn.type = 'button';
                    var icon = document.createElement('i');
                    icon.className = 'bi bi-three-dots-vertical';
                    btn.appendChild(icon);
                    btn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        row.classList.toggle('card-open');
                        icon.className = row.classList.contains('card-open') ? 'bi bi-x' : 'bi bi-three-dots-vertical';
                    });
                    cells[0].appendChild(btn);
                }
            });
        });
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initResponsiveTables);
    } else {
        initResponsiveTables();
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
