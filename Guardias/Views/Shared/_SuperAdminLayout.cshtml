<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Super Admin · OperApp</title>
    <link rel="icon" type="image/png" sizes="32x32" href="~/img/LogoOperapp.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/img/LogoOperapp.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
    <style>
        .sa-brand-badge { background: linear-gradient(135deg, #7B1FA2, #4A148C); color: #fff; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 8px; letter-spacing: 0.5px; text-transform: uppercase; }
    </style>
</head>
<body style="background:var(--bg);">

<div class="overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="admin-wrapper">
    <aside class="admin-sidebar" id="adminSidebar">
        <a href="/SuperAdmin" class="admin-sidebar-brand">
            <div class="icon"><img src="@Url.Content("~/img/LogoOperapp.jpeg")" alt="OperApp" style="border-radius:8px;" /></div>
            <div>
                <div class="name" style="background:linear-gradient(135deg,#2563EB,#7C3AED,#EC4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-weight:800;">OperApp</div>
                <div class="sub"><span class="sa-brand-badge">Super Admin</span></div>
            </div>
        </a>

        <div class="admin-nav-section">Principal</div>
        <a href="/SuperAdmin" class="admin-nav-link @(ViewData["SASection"] as string == "dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i> Dashboard Global
        </a>

        <div class="admin-nav-section">Gestión Global</div>
        <a href="/SuperAdmin/Empresas" class="admin-nav-link @(ViewData["SASection"] as string == "empresas" ? "active" : "")">
            <i class="bi bi-building-gear"></i> Empresas
        </a>
        <a href="/SuperAdmin/SuperAdmins" class="admin-nav-link @(ViewData["SASection"] as string == "superadmins" ? "active" : "")">
            <i class="bi bi-shield-fill-check"></i> Super Admins
        </a>

        <div class="admin-nav-section">Acceso Rápido</div>
        <a href="/Admin" class="admin-nav-link">
            <i class="bi bi-grid-1x2"></i> Panel de empresa
        </a>
        <a href="/Ronda/Historial" class="admin-nav-link">
            <i class="bi bi-phone"></i> Ver app guardia
        </a>
    </aside>

    <main class="admin-main">
        <div class="admin-topbar">
            <div>
                <button class="admin-menu-toggle" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
            </div>
            <div style="flex:1">
                <div class="admin-page-title">@ViewData["Title"]</div>
                @if (ViewData["PageSub"] != null)
                {
                    <div class="admin-page-sub">@ViewData["PageSub"]</div>
                }
            </div>
            <div style="display:flex;align-items:center;gap:8px;margin-right:8px;">
                <div style="text-align:right;line-height:1.2;">
                    <div style="font-size:12px;font-weight:600;color:var(--text);">@User.Identity!.Name</div>
                    <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;
                                 padding:2px 8px;border-radius:20px;background:#f3e5f5;color:#7B1FA2;">
                        <i class="bi bi-shield-fill-check"></i> Super Admin
                    </span>
                </div>
            </div>
            <form method="post" asp-controller="Account" asp-action="Logout" style="margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit" title="Cerrar sesión"
                        style="background:none;border:none;padding:8px;font-size:18px;color:var(--text2);cursor:pointer;display:flex;align-items:center;gap:6px;font-size:13px;">
                    <i class="bi bi-box-arrow-right"></i> Salir
                </button>
            </form>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert-ios alert-success mb-3">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            </div>
        }

        @RenderBody()
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
<script>
    function toggleSidebar() {
        document.getElementById('adminSidebar').classList.toggle('open');
        document.getElementById('sidebarOverlay').classList.toggle('show');
    }
    function closeSidebar() {
        document.getElementById('adminSidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('show');
    }
    function confirmarEliminar(formId, titulo, texto) {
        Swal.fire({
            title: titulo || '¿Eliminar?',
            text: texto || 'Esta acción no se puede deshacer.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#E05555',
            cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="bi bi-trash"></i> Sí, eliminar',
            cancelButtonText: 'Cancelar',
            reverseButtons: true,
            focusCancel: true
        }).then(result => {
            if (result.isConfirmed) document.getElementById(formId).submit();
        });
        return false;
    }
    function initResponsiveTables() {
        document.querySelectorAll('.admin-table').forEach(function(table) {
            if (table.dataset.respInit) return;
            table.dataset.respInit = '1';
            var headers = [];
            table.querySelectorAll('thead th').forEach(function(th) {
                var text = '';
                th.childNodes.forEach(function(n) { if (n.nodeType === 3) text += n.textContent; });
                headers.push(text.trim() || th.textContent.trim());
            });
            table.querySelectorAll('tbody tr').forEach(function(row) {
                var cells = Array.from(row.querySelectorAll('td'));
                cells.forEach(function(cell, i) {
                    if (i === 0 || i === cells.length - 1 || !headers[i]) return;
                    var lbl = document.createElement('span');
                    lbl.className = 'td-label';
                    lbl.textContent = headers[i];
                    var val = document.createElement('span');
                    val.className = 'td-value';
                    while (cell.firstChild) val.appendChild(cell.firstChild);
                    cell.appendChild(lbl);
                    cell.appendChild(val);
                });
            });
        });
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initResponsiveTables);
    } else {
        initResponsiveTables();
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
