<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <title>OperApp</title>
    <link rel="manifest" href="~/manifest.json" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/img/LogoOperapp.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/img/LogoOperapp.png" />
    <meta name="theme-color" content="#2563EB" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
</head>
<body class="mobile-body">

    <header class="app-header">
        <div class="app-header-icon" style="background:transparent;padding:0;">
            <img src="~/img/LogoOperapp.jpeg" alt="OperApp" style="width:44px;height:44px;object-fit:contain;border-radius:10px;" />
        </div>
        <div class="app-header-text">
            <div class="app-title" style="background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">OperApp</div>
            <div class="app-subtitle">@(User.FindFirst("EdificioNombre")?.Value ?? "Gestión de operaciones")</div>
        </div>
        <div style="display:flex;gap:8px;align-items:center;">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form method="post" asp-controller="Account" asp-action="Logout" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" title="Cerrar sesión"
                            style="background:none;border:none;padding:4px;font-size:20px;color:var(--text2);cursor:pointer;">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            }
            else
            {
                <a href="/Admin" class="admin-link" title="Panel Administrador">
                    <i class="bi bi-gear-fill"></i>
                </a>
            }
        </div>
    </header>

    <main class="app-content">
        @RenderBody()
    </main>

    <nav class="bottom-nav">
        <a href="/Ronda/Historial" class="bottom-nav-item @(ViewData["ActiveTab"] as string == "historial" ? "active" : "")">
            <i class="bi bi-clipboard2-check"></i>
            <span>Historial</span>
        </a>
        <a href="/Ronda/Nueva" class="bottom-nav-item @(ViewData["ActiveTab"] as string == "nueva" ? "active" : "")">
            <i class="bi bi-plus-circle"></i>
            <span>Nueva Ronda</span>
        </a>
        <a href="/Incidencia" class="bottom-nav-item @(ViewData["ActiveTab"] as string == "incidencias" ? "active" : "")">
            <i class="bi bi-exclamation-triangle"></i>
            <span>Incidencias</span>
        </a>
        <a href="/Pendientes" class="bottom-nav-item @(ViewData["ActiveTab"] as string == "pendientes" ? "active" : "")">
            <i class="bi bi-pencil-square"></i>
            <span>Pendientes</span>
        </a>
        <a href="/Tarea" class="bottom-nav-item @(ViewData["ActiveTab"] as string == "tareas" ? "active" : "")">
            <i class="bi bi-check2-square"></i>
            <span>Tareas</span>
        </a>
    </nav>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/offline.js" asp-append-version="true"></script>
    <script>
        // Guardar sync token mientras estamos online
        if (navigator.onLine) {
            fetch('/Sync/Token').then(r => r.json()).then(d => {
                if (d.token) window.OperApp && window.OperApp.saveSyncKey(d.token);
            }).catch(() => {});
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
