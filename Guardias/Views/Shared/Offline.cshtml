@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sin conexión — OperApp</title>
    <link rel="icon" type="image/png" sizes="32x32" href="~/img/LogoOperapp.png" />
    <link rel="stylesheet" href="~/css/mobile.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="mobile-body" style="display:flex;align-items:center;justify-content:center;min-height:100vh;">
    <div style="text-align:center;padding:32px 24px;max-width:320px;">
        <div style="font-size:72px;margin-bottom:16px;">📡</div>
        <h2 style="font-size:22px;font-weight:700;color:var(--text);margin-bottom:8px;">Sin conexión</h2>
        <p style="color:var(--text2);font-size:14px;line-height:1.6;margin-bottom:24px;">
            Esta página aún no está disponible offline.<br>
            Las páginas que hayas visitado antes sí están disponibles.
        </p>
        <button onclick="history.back()"
                style="background:var(--gradient,#2563EB);color:#fff;border:none;border-radius:14px;
                       padding:12px 28px;font-size:15px;font-weight:600;cursor:pointer;">
            <i class="bi bi-arrow-left me-2"></i> Volver
        </button>
        <div style="margin-top:20px;">
            <a href="/Ronda/Historial" style="color:var(--blue);font-size:13px;text-decoration:none;">
                <i class="bi bi-house me-1"></i> Ir al inicio
            </a>
        </div>
    </div>
    <script src="~/js/offline.js"></script>
</body>
</html>
