@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <title>Iniciar sesión — Control de Ronda</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
    <style>
        body { background: var(--bg); display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
        .login-card { background: #fff; border-radius: 20px; padding: 36px 28px; width: 100%; max-width: 380px; box-shadow: 0 4px 24px rgba(0,0,0,0.10); }
        .login-icon { width: 72px; height: 72px; background: var(--blue); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 34px; color: #fff; margin: 0 auto 20px; }
        .login-title { text-align: center; font-size: 22px; font-weight: 700; margin-bottom: 4px; }
        .login-sub { text-align: center; color: var(--text2); font-size: 14px; margin-bottom: 28px; }
        .login-hint { background: #f0f4ff; border-radius: 10px; padding: 10px 14px; font-size: 13px; color: #3a5fc8; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-icon"><i class="bi bi-shield-fill-check"></i></div>
        <div class="login-title">Control de Ronda</div>
        <div class="login-sub">Inicia sesión para continuar</div>

        @if (ViewContext.ModelState.ErrorCount > 0)
        {
            <div class="alert-ios alert-error" style="margin-bottom:16px;">
                @foreach (var entry in ViewContext.ModelState.Values)
                {
                    foreach (var err in entry.Errors)
                    {
                        <div><i class="bi bi-exclamation-circle me-1"></i>@err.ErrorMessage</div>
                    }
                }
            </div>
        }

        <form method="post" asp-controller="Account" asp-action="Login">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div style="margin-bottom:16px;">
                <label class="form-label-ios">Usuario</label>
                <input type="text" name="usuario" class="form-control-ios"
                       placeholder="Nombre de usuario" autocomplete="username" autofocus />
            </div>
            <div style="margin-bottom:24px;">
                <label class="form-label-ios">Contraseña</label>
                <input type="password" name="password" class="form-control-ios"
                       placeholder="Contraseña" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn-primary-ios">
                <i class="bi bi-box-arrow-in-right"></i> Ingresar
            </button>
        </form>

        <div class="login-hint">
            <i class="bi bi-info-circle me-1"></i>
            Cada edificio tiene su propio usuario. Consulta al administrador si no tienes credenciales.
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
</body>
</html>
