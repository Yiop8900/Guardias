@model Guardias.Models.Tarea
@{
    Layout = "_MobileLayout";
    ViewData["Title"] = Model.Titulo;
    var fotos = Model.Archivos.Where(a => a.EsImagen).ToList();
    var docs = Model.Archivos.Where(a => !a.EsImagen).ToList();
}

@if (TempData["Success"] != null)
    {
        <div class="alert-ios alert-success" style="margin-bottom:14px;">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-ios alert-error" style="margin-bottom:14px;">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
        </div>
    }

    <!-- Encabezado tarea -->
    <div class="admin-card" style="margin-bottom:16px;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:10px;">
            <div style="font-size:18px;font-weight:700;color:var(--text);">@Model.Titulo</div>
            @if (Model.CompletadaHoy)
            {
                <span class="badge-ios badge-done" style="flex-shrink:0;">✓ Completada hoy</span>
            }
            else
            {
                <span class="badge-ios badge-open" style="flex-shrink:0;">Pendiente</span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
        {
            <p style="font-size:14px;color:var(--text2);margin-bottom:12px;">@Model.Descripcion</p>
        }

        <div style="display:flex;flex-wrap:wrap;gap:8px;font-size:13px;color:var(--text2);">
            @if (Model.HoraProgramada.HasValue)
            {
                <span><i class="bi bi-clock me-1"></i>@Model.HoraProgramada.Value.ToString("HH:mm")</span>
            }
            <span><i class="bi bi-sun me-1"></i>
                @(Model.Turno == Guardias.Models.Turno.Manana ? "Mañana" :
                  Model.Turno == Guardias.Models.Turno.Tarde ? "Tarde" :
                  Model.Turno == Guardias.Models.Turno.Noche ? "Noche" : "Todos los turnos")
            </span>
            @if (Model.Edificio != null)
            {
                <span><i class="bi bi-building me-1"></i>@Model.Edificio.Nombre</span>
            }
        </div>

        @if (!Model.CompletadaHoy)
        {
            if (Model.Archivos.Any())
            {
                <form id="formCompletar" method="post" asp-controller="Tarea" asp-action="Completar" asp-route-id="@Model.Id" style="margin-top:14px;">
                    @Html.AntiForgeryToken()
                    <button type="submit" id="btnCompletar" class="btn-primary-ios">
                        <i class="bi bi-check2-circle"></i> Marcar como completada
                    </button>
                </form>
            }
            else
            {
                <div id="noArchivoMsg" style="margin-top:14px;padding:12px 14px;background:#FEF2F2;border-radius:12px;font-size:13px;color:#DC2626;display:flex;align-items:center;gap:8px;">
                    <i class="bi bi-paperclip"></i> Adjunta al menos un archivo para poder completar esta tarea
                </div>
            }
        }
        else
        {
            <div style="margin-top:14px;padding:10px 14px;background:#E8F5E9;border-radius:12px;font-size:13px;color:#2E7D32;display:flex;align-items:center;gap:8px;">
                <i class="bi bi-check-circle-fill"></i>
                Completada hoy a las @Model.FechaCompletada!.Value.ToString("HH:mm") — se restablecerá mañana
            </div>
        }
    </div>

    <!-- Subir archivos -->
    <div class="admin-card" style="margin-bottom:16px;">
        <div style="font-weight:600;font-size:15px;margin-bottom:14px;color:var(--text);">
            <i class="bi bi-paperclip" style="color:var(--blue);"></i> Adjuntar archivos
        </div>

        <form method="post" asp-controller="Tarea" asp-action="SubirArchivos" asp-route-id="@Model.Id"
              enctype="multipart/form-data" id="uploadForm">
            @Html.AntiForgeryToken()

            <!-- Inputs ocultos -->
            <input type="file" id="inputCamara" name="archivos" multiple accept="image/*" capture="environment" style="display:none;" onchange="submitUpload(this)" />
            <input type="file" id="inputGaleria" name="archivos" multiple accept="image/*" style="display:none;" onchange="submitUpload(this)" />
            <input type="file" id="inputDocumento" name="archivos" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.txt,.png,.jpg,.jpeg" style="display:none;" onchange="submitUpload(this)" />

            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
                <button type="button" onclick="document.getElementById('inputCamara').click()"
                        style="background:#EFF6FF;border:2px dashed #93C5FD;border-radius:14px;padding:16px 8px;
                               text-align:center;cursor:pointer;color:#2563EB;font-size:12px;font-weight:600;line-height:1.4;">
                    <i class="bi bi-camera-fill" style="font-size:24px;display:block;margin-bottom:6px;"></i>
                    Cámara
                </button>
                <button type="button" onclick="document.getElementById('inputGaleria').click()"
                        style="background:#F0FDF4;border:2px dashed #86EFAC;border-radius:14px;padding:16px 8px;
                               text-align:center;cursor:pointer;color:#16A34A;font-size:12px;font-weight:600;line-height:1.4;">
                    <i class="bi bi-images" style="font-size:24px;display:block;margin-bottom:6px;"></i>
                    Galería
                </button>
                <button type="button" onclick="document.getElementById('inputDocumento').click()"
                        style="background:#FFF7ED;border:2px dashed #FDC87A;border-radius:14px;padding:16px 8px;
                               text-align:center;cursor:pointer;color:#EA580C;font-size:12px;font-weight:600;line-height:1.4;">
                    <i class="bi bi-file-earmark-arrow-up" style="font-size:24px;display:block;margin-bottom:6px;"></i>
                    Documento
                </button>
            </div>

            <div id="uploadingMsg" style="display:none;text-align:center;padding:12px;color:var(--blue);font-size:13px;">
                <i class="bi bi-arrow-repeat spin"></i> Subiendo...
            </div>
        </form>
    </div>

    <!-- Fotos adjuntas -->
    @if (fotos.Any())
    {
        <div class="admin-card" style="margin-bottom:16px;">
            <div style="font-weight:600;font-size:15px;margin-bottom:12px;color:var(--text);">
                <i class="bi bi-images" style="color:var(--green);"></i> Fotos (@fotos.Count)
            </div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;">
                @foreach (var foto in fotos)
                {
                    <div style="position:relative;">
                        <a href="~/uploads/tareas/@foto.NombreArchivo" target="_blank">
                            <img src="~/uploads/tareas/@foto.NombreArchivo"
                                 style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:10px;" />
                        </a>
                        <form method="post" asp-controller="Tarea" asp-action="EliminarArchivo" style="position:absolute;top:4px;right:4px;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="archivoId" value="@foto.Id" />
                            <input type="hidden" name="tareaId" value="@Model.Id" />
                            <button type="submit"
                                    style="background:rgba(0,0,0,0.55);border:none;border-radius:50%;width:26px;height:26px;
                                           color:#fff;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                                <i class="bi bi-x"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Documentos adjuntos -->
    @if (docs.Any())
    {
        <div class="admin-card" style="margin-bottom:16px;">
            <div style="font-weight:600;font-size:15px;margin-bottom:12px;color:var(--text);">
                <i class="bi bi-file-earmark-text" style="color:var(--orange);"></i> Documentos (@docs.Count)
            </div>
            @foreach (var doc in docs)
            {
                <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;
                             padding:10px 12px;background:var(--bg);border-radius:10px;margin-bottom:8px;">
                    <a href="~/uploads/tareas/@doc.NombreArchivo" target="_blank"
                       style="display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--text);flex:1;min-width:0;">
                        <i class="bi bi-file-earmark-pdf" style="font-size:22px;color:var(--orange);flex-shrink:0;"></i>
                        <div style="min-width:0;">
                            <div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@doc.NombreOriginal</div>
                            <div style="font-size:11px;color:var(--text2);">@doc.FechaSubida.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    </a>
                    <form method="post" asp-controller="Tarea" asp-action="EliminarArchivo">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="archivoId" value="@doc.Id" />
                        <input type="hidden" name="tareaId" value="@Model.Id" />
                        <button type="submit"
                                style="background:none;border:none;color:var(--red);font-size:18px;cursor:pointer;padding:4px;">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    }

    @if (!fotos.Any() && !docs.Any())
    {
        <div style="text-align:center;padding:20px;color:var(--text2);font-size:14px;">
            <i class="bi bi-paperclip" style="font-size:32px;display:block;margin-bottom:8px;opacity:0.4;"></i>
            Sin archivos adjuntos aún
        </div>
    }

    <a href="/Tarea" style="display:block;text-align:center;color:var(--blue);font-size:14px;padding:10px;">
        <i class="bi bi-arrow-left me-1"></i> Volver a mis tareas
    </a>

<style>
    .spin { animation: spin 1s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
var TAREA_ID = @Model.Id;

// Intercepción offline para subida de archivos
async function submitUpload(inputEl) {
    var files = inputEl.files;
    if (!files || files.length === 0) return;

    if (!navigator.onLine) {
        // Modo offline: encolar en IndexedDB
        document.getElementById('uploadingMsg').style.display = 'block';
        document.getElementById('uploadingMsg').innerHTML = '<i class="bi bi-clock"></i> Sin conexión — archivo guardado, se subirá al reconectar';
        document.getElementById('uploadingMsg').style.color = '#E65100';

        for (var i = 0; i < files.length; i++) {
            await window.OperApp.subirArchivoOffline(TAREA_ID, files[i], function(id, nombre) {
                addOfflineFilePreview(nombre);
            });
        }
        // Habilitar completar si hay archivos (offline)
        enableCompletarIfNeeded();
        return;
    }

    // Online: submit normal
    document.getElementById('uploadingMsg').style.display = 'block';
    document.getElementById('uploadingMsg').innerHTML = '<i class="bi bi-arrow-repeat spin"></i> Subiendo...';
    document.getElementById('uploadingMsg').style.color = 'var(--blue)';
    document.getElementById('uploadForm').submit();
}

function addOfflineFilePreview(nombre) {
    var container = document.getElementById('offline-files-preview');
    if (!container) {
        container = document.createElement('div');
        container.id = 'offline-files-preview';
        container.style.cssText = 'margin-top:12px;padding:10px;background:#FFF7ED;border-radius:10px;';
        container.innerHTML = '<div style="font-size:12px;font-weight:600;color:#EA580C;margin-bottom:6px;"><i class="bi bi-clock"></i> Pendientes de sincronizar</div>';
        document.getElementById('uploadForm').after(container);
    }
    var item = document.createElement('div');
    item.style.cssText = 'font-size:12px;color:var(--text2);padding:2px 0;';
    item.innerHTML = '<i class="bi bi-file-earmark me-1"></i>' + nombre;
    container.appendChild(item);
    // Mostrar botón de completar
    enableCompletarIfNeeded();
}

function enableCompletarIfNeeded() {
    var noMsg = document.getElementById('noArchivoMsg');
    if (noMsg) {
        noMsg.style.display = 'none';
        // Crear botón completar offline
        if (!document.getElementById('btnCompletarOffline')) {
            var btn = document.createElement('button');
            btn.id = 'btnCompletarOffline';
            btn.type = 'button';
            btn.className = 'btn-primary-ios';
            btn.style.marginTop = '14px';
            btn.innerHTML = '<i class="bi bi-check2-circle"></i> Marcar como completada';
            btn.onclick = completarOffline;
            noMsg.after(btn);
        }
    }
}

async function completarOffline() {
    if (!navigator.onLine) {
        await window.OperApp.completarOffline(TAREA_ID, null);
        var btn = document.getElementById('btnCompletarOffline') || document.getElementById('btnCompletar');
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-clock"></i> Pendiente de sync';
            btn.style.background = '#FEF3C7';
            btn.style.color = '#92400E';
        }
    } else {
        document.getElementById('formCompletar') && document.getElementById('formCompletar').submit();
    }
}

// Interceptar el form de completar si hay offline
document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('formCompletar');
    if (form) {
        form.addEventListener('submit', async function(e) {
            if (!navigator.onLine) {
                e.preventDefault();
                await completarOffline();
            }
        });
    }
});
</script>
